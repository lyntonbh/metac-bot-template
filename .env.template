# Required
METACULUS_TOKEN=1234567890
OPENROUTER_API_KEY=1234567890

# Optional
PERPLEXITY_API_KEY=1234567890
ASKNEWS_CLIENT_ID=
ASKNEWS_SECRET=
OPENAI_API_KEY=1234567890
EXA_API_KEY=1234567890
ANTHROPIC_API_KEY=1234567890

# Optional model policy
BASE_RATE_FORECASTER_MODEL=openrouter/deepseek/deepseek-v4-pro
INSIDE_VIEW_FORECASTER_MODEL=openrouter/z-ai/glm-5.1
MARKET_DATA_FORECASTER_MODEL=openrouter/mistralai/mistral-large-2512
ESCALATION_FORECASTER_MODEL=openrouter/openai/gpt-5.5
DEFAULT_FORECASTER_MODEL=openrouter/mistralai/mistral-large-2512
SUMMARIZER_MODEL=openrouter/openai/gpt-5-nano
PARSER_MODEL=openrouter/openai/gpt-5-nano
# AskNews is tried first by default; RESEARCHER_FALLBACK_MODEL runs if AskNews is missing or fails.
RESEARCHER_MODEL=random
RESEARCHER_RANDOM_MODELS=asknews/news-summaries,perplexity,exa
RESEARCHER_RANDOM_SEED=
RESEARCHER_FALLBACK_MODEL=exa
PERPLEXITY_RESEARCHER_MODEL=perplexity/sonar-pro
OPENROUTER_PERPLEXITY_RESEARCHER_MODEL=openrouter/perplexity/sonar-pro
EXA_RESEARCHER_MODEL=exa/exa
FORECASTER_MAX_TOKENS=4096
ESCALATION_MAX_TOKENS=4096
RESEARCHER_MAX_TOKENS=4096
RESEARCHER_TIMEOUT_SECONDS=240
SUMMARIZER_MAX_TOKENS=2048
PARSER_MAX_TOKENS=1024
CONTINUE_ON_QUESTION_ERRORS=false

# Optional experiment controls
# Keep this off for official tournament runs unless you explicitly want A/B testing.
ENABLE_EXPERIMENT_VARIANTS=false
EXPERIMENT_MODE=off
EXPERIMENT_VARIANT=
EXPERIMENT_SEED=
EXPERIMENT_LOG_DIR=experiment_logs
ENABLE_EXPERIMENT_LOGGING=true
ALLOW_PUBLISH_EXPERIMENTS=false
BINARY_ESCALATION_SPREAD=0.20
MULTIPLE_CHOICE_ESCALATION_SPREAD=0.22
NUMERIC_ESCALATION_RANGE_FRACTION=0.12
NUMERIC_ESCALATION_RELATIVE_FRACTION=0.50

# Optional research controls
ENABLE_DIRECT_STRUCTURED_RESEARCH=true
ENABLE_DIRECT_EVIDENCE_CACHE=true
DIRECT_EVIDENCE_CACHE_HOURS=6
DIRECT_EVIDENCE_MAX_ITEMS=20
ENABLE_DIRECT_EVIDENCE_SYNTHESIS=true
ENABLE_DIRECT_MARKET_APIS=true
INCLUDE_WEAK_MARKET_EVIDENCE=false
ENABLE_SUPPLEMENTAL_WEB_RESEARCH=true
ENABLE_MARKET_PRIOR_RESEARCH=true
KALSHI_API_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
POLYMARKET_GAMMA_MARKETS_URL=https://gamma-api.polymarket.com/markets
POLYMARKET_GAMMA_EVENTS_URL=https://gamma-api.polymarket.com/events
MARKET_PRIOR_SEARCH_MODEL=openrouter/mistralai/mistral-large-2512
ENABLE_OFFICIAL_DATA_RESEARCH=true
OFFICIAL_DATA_SEARCH_MODEL=openrouter/mistralai/mistral-large-2512
FRED_API_KEY=
ENABLE_SEC_EDGAR_RESEARCH=true
SEC_USER_AGENT=metac-bot-template research bot; set SEC_USER_AGENT with contact email
ENABLE_FIVETHIRTYEIGHT_POLLS=true
ENABLE_ACLED_RESEARCH=false
ACLED_API_URL=https://api.acleddata.com/acled/read
ACLED_EMAIL=
ACLED_API_KEY=

# Optional deep research controls
# Deep research runs on disagreement by default if Perplexity, Exa, or OpenRouter is configured.
ENABLE_DEEP_RESEARCH_ON_DISAGREEMENT=true
ENABLE_DEEP_RESEARCH_ON_HIGH_VALUE=false
DEEP_RESEARCH_ON_ALL_QUESTIONS=false
DEEP_RESEARCH_PROVIDER=auto
DEEP_RESEARCH_MAX_TOKENS=4096
DEEP_RESEARCH_MODEL=
PERPLEXITY_DEEP_RESEARCH_MODEL=perplexity/sonar-pro
OPENROUTER_PERPLEXITY_DEEP_RESEARCH_MODEL=openrouter/perplexity/sonar-pro
EXA_DEEP_RESEARCH_MODEL=exa/exa
HIGH_VALUE_RESEARCH_KEYWORDS=frontier ai,agi,artificial intelligence,ai benchmark,llm,model release,election,poll,inflation,gdp,cpi,unemployment,interest rate,central bank,war,ceasefire,nuclear
